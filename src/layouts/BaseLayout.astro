---
import '../styles/global.css';
import { copy, languages, type Lang } from '../i18n/content';
const { lang, title, description } = Astro.props as { lang: Lang; title: string; description: string };
const canonical = new URL(Astro.url.pathname, Astro.url.origin).toString();
const t = copy[lang];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#17322a" />
    <link rel="canonical" href={canonical} />
    {languages.map((language) => <link rel="alternate" hreflang={language} href={new URL(`/${language}/`, Astro.url.origin).toString()} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/pl/', Astro.url.origin).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={t.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/images/restaurant-hero.png', Astro.url.origin).toString()} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'Restaurant', name: 'INDIAN CURRY WŁOCHY',
      servesCuisine: 'Indian', priceRange: '$$', telephone: '+48500091313',
      image: new URL('/images/restaurant-hero.png', Astro.url.origin).toString(),
      address: { '@type': 'PostalAddress', streetAddress: 'Równoległa 2', addressLocality: 'Warszawa', postalCode: '02-232', addressCountry: 'PL' },
      openingHours: 'Mo-Su 11:00-22:00', hasMenu: 'https://indian-curry-rownolegla.order.app.hd.digital/menus'
    })} />
  </head>
  <body><slot /></body>
</html>
