---
import '../styles/global.css'; import {copy,languages,type Lang} from '../i18n/content';
const {lang,title,description}=Astro.props as {lang:Lang;title:string;description:string}; const t=copy[lang]; const path=Astro.url.pathname.replace(/^\/(pl|en|hi)/,'')||'/'; const url=Astro.url.toString();
---
<!doctype html><html lang={lang}><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><meta name="description" content={description}/><meta name="theme-color" content="#21130f"/><link rel="canonical" href={url}/>{languages.map(item=><link rel="alternate" hreflang={item} href={new URL(`/${item}${path}`,Astro.url.origin).toString()}/>)}<link rel="alternate" hreflang="x-default" href={new URL(`/pl${path}`,Astro.url.origin).toString()}/><meta property="og:type" content="website"/><meta property="og:locale" content={t.locale}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:image" content={new URL('/images/restaurant-hero.png',Astro.url.origin).toString()}/><title>{title}</title><script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'Restaurant',name:'INDIAN CURRY WŁOCHY',servesCuisine:'Indian',telephone:'+48500091313',priceRange:'$$',address:{'@type':'PostalAddress',streetAddress:'Równoległa 2',postalCode:'02-232',addressLocality:'Warszawa',addressCountry:'PL'},openingHours:'Mo-Su 11:00-22:00',hasMenu:'https://indian-curry-rownolegla.order.app.hd.digital/menus',sameAs:['https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9']})}/></head><body><slot/></body></html>
