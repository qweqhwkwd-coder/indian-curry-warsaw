---
import '../styles/global.css';
import { languages, copy, type Lang } from '../i18n/content';
const { lang, title, description } = Astro.props as { lang: Lang; title: string; description: string };
const base = Astro.url.origin;
---
<!doctype html><html lang={lang}><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><meta name="description" content={description}><meta name="theme-color" content="#192318"><title>{title}</title>{languages.map((item) => <link rel="alternate" hreflang={item} href={`${base}/${item}/`} />)}<link rel="alternate" hreflang="x-default" href={`${base}/pl/`} /><meta property="og:type" content="website"><meta property="og:locale" content={copy[lang].locale}><meta property="og:title" content={title}><meta property="og:description" content={description}><meta property="og:image" content={`${base}/images/hero-curry.jpg`}><script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'Restaurant',name:'Indian Curry 2',servesCuisine:'Indian',priceRange:'$$',address:{'@type':'PostalAddress',streetAddress:'Równoległa 2',addressLocality:'Warszawa',postalCode:'02-235',addressCountry:'PL'},openingHours:'Mo-Su 10:00-22:00',hasMenu:'https://indian-curry-rownolegla.order.app.hd.digital/menus'})}></script></head><body><slot /></body></html>
<style is:global>html[lang="hi"] h1,html[lang="hi"] h2,html[lang="hi"] h3{font-family:"Noto Sans Devanagari",sans-serif;letter-spacing:-.035em;line-height:1.05}html[lang="hi"] .hero-title{max-width:740px}html[lang="hi"] .menu-heading h2{font-size:clamp(2.6rem,5.8vw,5.4rem)}.brand>.logo{display:inline-flex!important;width:auto!important;height:auto!important;margin:0!important;border:0!important;border-radius:0!important;font:inherit!important}.brand .logo-type{display:grid!important;width:auto!important;height:auto!important;margin:0!important;border:0!important;border-radius:0!important;font:800 .72rem/.95 var(--font)!important}.brand .logo-type b,.brand .logo-type strong{display:block!important;width:auto!important;height:auto!important;margin:0!important;border:0!important;border-radius:0!important}.brand .logo-type i{color:var(--acid)!important}@media(max-width:600px){.header{padding:.9rem 1rem!important}.brand .logo svg{width:35px!important;height:35px!important}.brand .logo-type{font-size:.64rem!important}.new-hero{display:flex!important;flex-direction:column!important;min-height:0!important;padding:7.4rem 1.2rem 1.1rem!important}.hero-meta{font-size:.55rem!important}.hero-title{align-self:auto!important;margin:2.8rem 0 0!important}.hero-title h1{font-size:clamp(3.2rem,15vw,4.6rem)!important;line-height:.84!important}.hero-title>p:not(.hero-kicker){max-width:100%!important;font-size:.9rem!important}.hero-photo{position:relative!important;right:auto!important;bottom:auto!important;align-self:flex-end!important;width:76%!important;margin:1.7rem 0 .8rem!important;opacity:1!important;transform:rotate(3deg)!important}.hero-photo img{border-width:5px!important}.hero-photo figcaption{display:none!important}.hero-footer{width:100%;font-size:.53rem!important}.menu-editorial{gap:2.1rem;padding:4rem 1.2rem}.menu-heading h2,.heat-copy h2,.visit-card h2{font-size:clamp(2.85rem,13vw,4rem);line-height:.86}.dish{gap:.7rem;padding:1.1rem 0}.dish h3{font-size:2rem}.dish small{font-size:.72rem}.heat-section{padding:4rem 1.2rem}.heat-number{font-size:14rem}.heat-copy>span{font-size:.87rem}.heat-scale{margin-top:.2rem}.heat-scale b{font-size:2rem}.visit-card{padding:4rem 1.2rem}.address-graphic{min-height:310px}.address-graphic span{font-size:2.7rem}.address-graphic b{font-size:9rem}}</style>
<style is:global>
  :root{--ink:#20150e!important;--milk:#f8f2e7!important;--acid:#c8803c!important;--red:#9b3d25!important;--lilac:#ded0bb!important}
  .header{border-bottom:1px solid #ffffff33!important}.new-hero{display:block!important;min-height:720px!important;padding:11rem clamp(1.4rem,8vw,9rem) 4rem!important;background:linear-gradient(90deg,rgba(18,10,5,.8) 0%,rgba(18,10,5,.52) 47%,rgba(18,10,5,.12) 100%),url('/images/restaurant-hero.png') center/cover!important}.hero-orb,.hero-photo{display:none!important}.hero-meta{display:none!important}.hero-title{max-width:680px!important;margin:0!important}.hero-kicker{color:#e9d2ae!important}.hero-title h1{font-family:Georgia,serif!important;font-size:clamp(3.6rem,7vw,7rem)!important;line-height:.9!important;letter-spacing:-.055em!important;text-transform:none!important}.hero-title h1 em{color:#e9d2ae!important;font-style:italic!important}.hero-title>p:not(.hero-kicker){max-width:440px!important;font-size:1rem!important}.hero-order{border-color:#e9d2ae!important;background:#e9d2ae!important;color:#20150e!important}.hero-order b{background:#9b3d25!important;color:#fff!important}.hero-footer{position:absolute!important;right:clamp(1.4rem,8vw,9rem)!important;bottom:1.6rem!important;left:clamp(1.4rem,8vw,9rem)!important}.tape{background:#9b3d25!important;color:#fff!important}.tape b{color:#e9d2ae!important}.menu-editorial{background:#f8f2e7!important}.menu-heading h2,.heat-copy h2,.visit-card h2{font-family:Georgia,serif!important;font-weight:400!important;text-transform:none!important;letter-spacing:-.05em!important}.menu-heading h2 em{color:#9b3d25!important}.menu-heading>a{background:#9b3d25!important}.dish-2 h3,.dish-3 h3{color:#20150e!important}.heat-section{background:#5b281a!important}.heat-number{color:#4a1f14!important}.visit-card{background:#ded0bb!important}.address-graphic{background:#2e1b12!important}.address-graphic{color:#e9d2ae!important}.address-graphic:before,.address-graphic:after{border-color:#e9d2ae66!important}@media(max-width:600px){.new-hero{display:flex!important;min-height:680px!important;padding:8.8rem 1.35rem 3rem!important;background:linear-gradient(180deg,rgba(18,10,5,.5),rgba(18,10,5,.85)),url('/images/restaurant-hero.png') 62% center/cover!important}.hero-title{margin:auto 0 0!important}.hero-title h1{font-size:clamp(3.15rem,14vw,4.6rem)!important}.hero-title>p:not(.hero-kicker){font-size:.92rem!important}.hero-footer{position:static!important;margin-top:2rem!important}.hero-footer span:last-child{display:none!important}.menu-editorial{padding:4rem 1.35rem!important}.menu-heading h2,.heat-copy h2,.visit-card h2{font-size:clamp(2.7rem,12vw,3.9rem)!important}}
</style>
