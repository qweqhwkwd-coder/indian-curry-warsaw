---
import '../styles/global.css';
import { languages, copy, type Lang } from '../i18n/content';
const { lang, title, description } = Astro.props as { lang: Lang; title: string; description: string };
const base = Astro.url.origin;
---
<!doctype html><html lang={lang}><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><meta name="description" content={description}><meta name="theme-color" content="#192318"><title>{title}</title>{languages.map((item) => <link rel="alternate" hreflang={item} href={`${base}/${item}/`} />)}<link rel="alternate" hreflang="x-default" href={`${base}/pl/`} /><meta property="og:type" content="website"><meta property="og:locale" content={copy[lang].locale}><meta property="og:title" content={title}><meta property="og:description" content={description}><meta property="og:image" content={`${base}/images/hero-curry.jpg`}><script type="application/ld+json" set:html={JSON.stringify({'@context':'https://schema.org','@type':'Restaurant',name:'Indian Curry 2',servesCuisine:'Indian',priceRange:'$$',address:{'@type':'PostalAddress',streetAddress:'Równoległa 2',addressLocality:'Warszawa',postalCode:'02-235',addressCountry:'PL'},openingHours:'Mo-Su 10:00-22:00',hasMenu:'https://indian-curry-rownolegla.order.app.hd.digital/menus'})}></script></head><body><slot /></body></html>
<style is:global>html[lang="hi"] h1,html[lang="hi"] h2,html[lang="hi"] h3{font-family:"Noto Sans Devanagari",sans-serif;letter-spacing:-.035em;line-height:1.05}html[lang="hi"] .hero-title{max-width:740px}html[lang="hi"] .menu-heading h2{font-size:clamp(2.6rem,5.8vw,5.4rem)}@media(max-width:600px){.header{padding:.9rem 1rem}.logo svg{width:35px;height:35px}.logo-type{font-size:.64rem}.new-hero{min-height:700px;padding:6.3rem 1.2rem 1.1rem}.hero-meta{font-size:.55rem}.hero-title{margin:5rem 0 2.2rem}.hero-title h1{font-size:clamp(3.4rem,16vw,5.2rem);line-height:.82}.hero-title>p:not(.hero-kicker){max-width:280px;font-size:.86rem}.hero-photo{right:1.15rem;bottom:5.4rem;width:175px;opacity:.68;transform:rotate(4deg)}.hero-photo img{border-width:5px}.hero-photo figcaption{right:-.7rem;bottom:.7rem;font-size:1rem}.hero-footer{font-size:.53rem}.menu-editorial{gap:2.1rem;padding:4rem 1.2rem}.menu-heading h2,.heat-copy h2,.visit-card h2{font-size:clamp(2.85rem,13vw,4rem);line-height:.86}.dish{gap:.7rem;padding:1.1rem 0}.dish h3{font-size:2rem}.dish small{font-size:.72rem}.heat-section{padding:4rem 1.2rem}.heat-number{font-size:14rem}.heat-copy>span{font-size:.87rem}.heat-scale{margin-top:.2rem}.heat-scale b{font-size:2rem}.visit-card{padding:4rem 1.2rem}.address-graphic{min-height:310px}.address-graphic span{font-size:2.7rem}.address-graphic b{font-size:9rem}}</style>
