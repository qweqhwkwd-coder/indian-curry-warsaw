---
import { languages, copy, type Lang } from '../i18n/content';
import Logo from './Logo.astro';
import Arrow from './Arrow.astro';
const { lang } = Astro.props as { lang: Lang };
const t = copy[lang];
const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<a class="skip" href="#main">{t.home.skip}</a><header class="header"><a class="brand" href={`/${lang}/`} aria-label="Indian Curry 2"><Logo /></a><nav aria-label={t.home.navigation}><a href={`/${lang}/menu`}>{t.nav[0]}</a><a href={`/${lang}/#story`}>{t.nav[1]}</a><a href={`/${lang}/visit`}>{t.nav[2]}</a></nav><div class="tools"><div class="languages" aria-label={t.home.language}>{languages.map((item) => <a class:list={{active:item === lang}} href={`/${item}/`} lang={item}>{item === 'hi' ? 'हिं' : item.toUpperCase()}</a>)}</div><a class="order" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} <Arrow /></a></div></header>
