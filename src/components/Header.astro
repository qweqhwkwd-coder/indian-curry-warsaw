---
import { languages, copy, type Lang } from '../i18n/content';
const { lang } = Astro.props as { lang: Lang };
const t = copy[lang];
const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<a class="skip" href="#main">Skip to content</a><header class="header"><a class="brand" href={`/${lang}/`} aria-label="Indian Curry 2"><span>IC</span>Indian<br/>Curry <i>2</i></a><nav aria-label="Main navigation"><a href={`/${lang}/menu`}>{t.nav[0]}</a><a href={`/${lang}/#story`}>{t.nav[1]}</a><a href={`/${lang}/visit`}>{t.nav[2]}</a></nav><div class="tools"><div class="languages" aria-label="Language selector">{languages.map((item) => <a class:list={{active:item === lang}} href={`/${item}/`} lang={item}>{item === 'hi' ? 'हिं' : item.toUpperCase()}</a>)}</div><a class="order" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} ↗</a></div></header>
