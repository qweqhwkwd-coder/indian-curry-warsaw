---
const { compact = false } = Astro.props as { compact?: boolean };
---
<span class:list={{ logo: true, compact }} aria-hidden="true"><svg viewBox="0 0 52 52" focusable="false"><path d="M9 24.5h34c0 10.2-6.5 17-17 17s-17-6.8-17-17Z"/><path d="M7 22.5h38"/><path d="M16 13.5c0 3.2-2.8 4.6-2.8 7.5M26 9.5c0 4-3.3 5.5-3.3 10.5M36 13.5c0 3.2-2.8 4.6-2.8 7.5"/></svg><span class="logo-type"><b>INDIAN</b><strong>CURRY <i>2</i></strong></span></span>
<style>
  .logo{display:inline-flex;align-items:center;gap:.5rem;color:var(--milk)}.logo svg{width:40px;height:40px;stroke:currentColor;fill:none;stroke-width:2.1;stroke-linecap:round;stroke-linejoin:round}.logo-type{display:grid;gap:.05rem;font:800 .72rem/.95 var(--font);letter-spacing:.065em}.logo-type b{color:var(--milk)}.logo-type strong{font-weight:800}.logo-type i{color:var(--acid);font-style:normal}.compact svg{width:34px;height:34px}.compact .logo-type{font-size:.64rem}
</style>
