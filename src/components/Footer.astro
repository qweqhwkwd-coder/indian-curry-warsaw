---
import { copy, PHONE, PHONE_DISPLAY, MAPS_URL, type Lang } from '../i18n/content';
import Logo from './Logo.astro';
import Arrow from './Arrow.astro';
const { lang } = Astro.props as { lang: Lang };
const t = copy[lang];
---

<footer class="footer">
  <div class="footer-brand">
    <a class="brand" href={`/${lang}/`} aria-label={t.name}><Logo /></a>
    <p>{t.footer}</p>
  </div>

  <address>
    Równoległa 2<br />02-232 Warszawa<br />
    <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a>
  </address>

  <div class="footer-actions">
    <a class="footer-link" href={MAPS_URL} target="_blank" rel="noopener noreferrer">
      Google Maps <Arrow />
    </a>
    <p class="footer-rights">© 2025 {t.name}. {t.rights}</p>
  </div>
</footer>
