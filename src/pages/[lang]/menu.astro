---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import {languages,copy,dishes,langIndex,type Lang} from '../../i18n/content'; export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang]; const i=langIndex(lang); const order='https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.nav.menu} — ${t.name}`} description={t.menuPageLead}><Header {lang}/><main id="main" class="page"><section class="page-head"><p class="kicker">{t.nav.menu}</p><h1 set:html={t.menuPageTitle}/><p>{t.menuPageLead}</p></section><section class="page-list">{dishes.map((dish,n)=><article><span>0{n+1}</span><div><h2>{dish.name}</h2><p>{dish.description[i]}</p></div></article>)}<a class="button" href={order} target="_blank" rel="noopener noreferrer">{t.menuLink} <span>↗</span></a></section></main><Footer {lang}/></BaseLayout>
