---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content'; export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang]; const i=langIndex(lang); const orderUrl='https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.nav[0]} | ${t.name}`} description={t.menuLead}><Header {lang}/><main id="main" class="section" style="padding-top:9rem"><p class="kicker">{t.nav[0]}</p><h1>{t.menuTitle}</h1><p class="lead">{t.menuLead}</p><div class="cards">{dishes.map(d=><article><p class="tag">{d.tag[i]}</p><h2>{d.name}</h2><p>{d.text[i]}</p><div><strong>{d.price}</strong><a href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} ↗</a></div></article>)}</div></main><Footer {lang}/></BaseLayout>
