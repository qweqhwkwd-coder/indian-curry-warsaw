---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content';
export function getStaticPaths() { return languages.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Lang; const t = copy[lang]; const index = langIndex(lang); const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.nav.menu} — ${t.name}`} description={t.menuPageLead}><Header {lang} light /><main id="main" class="menu-page"><section class="menu-page__hero"><p class="eyebrow eyebrow--dark">{t.nav.menu}</p><h1 set:html={t.menuPageTitle} /><p>{t.menuPageLead}</p></section><section class="menu-page__body"><div class="categories">{t.menuCategories.map((category, i) => <span><b>0{i + 1}</b>{category}</span>)}</div><div class="menu-dishes">{dishes.map((dish) => <article><div><p>{dish.type[index]}</p><h2>{dish.name}</h2><span>{dish.description[index]}</span></div><strong>{dish.price}</strong></article>)}</div><div class="menu-page__cta"><p>{t.menuNote}</p><a class="button button--light" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order}<span>↗</span></a></div></section></main><Footer {lang} /></BaseLayout>
