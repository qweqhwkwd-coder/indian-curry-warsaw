---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content';
export function getStaticPaths() { return languages.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Lang; const t = copy[lang]; const index = langIndex(lang);
const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.name} — ${t.hero}`} description={t.lead}>
  <Header {lang} />
  <main id="main">
    <section class="hero">
      <div class="hero__grain"></div><div class="hero__arc" aria-hidden="true">TANDOOR · SPICE · SOUL · TANDOOR · SPICE · SOUL ·</div>
      <div class="hero__content"><p class="eyebrow">{t.heroEyebrow}</p><h1>{t.hero}</h1><p class="hero__lead">{t.lead}</p><a class="button button--light" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order}<span>↗</span></a></div>
      <div class="hero__bottom"><span>{t.heroNote}</span><span>{t.service}</span></div>
    </section>
    <div class="marquee" aria-hidden="true"><div>CURRY · TANDOOR · NAAN · BIRYANI · PANEER · CURRY · TANDOOR · NAAN · BIRYANI · PANEER ·</div></div>
    <section class="favourites section-pad" id="menu">
      <div class="section-heading"><p class="eyebrow eyebrow--dark">{t.menuEyebrow}</p><h2 set:html={t.menuTitle} /><p>{t.menuLead}</p><a class="text-link" href={`/${lang}/menu`}>{t.allMenu} <span>↗</span></a></div>
      <div class="dish-list">{dishes.map((dish) => <article class="dish"><p>{dish.number} · {dish.type[index]}</p><h3>{dish.name}</h3><span>{dish.description[index]}</span><strong>{dish.price}</strong></article>)}</div>
    </section>
    <section class="story" id="story"><div class="story__picture"><span>INDIAN<br />CURRY</span></div><div class="story__copy"><p class="eyebrow">{t.storyEyebrow}</p><h2 set:html={t.storyTitle} /><p>{t.storyText}</p><div class="story__facts"><span><b>11:00</b>–22:00<br /><small>{t.openDaily}</small></span><span><b>4.9</b>/5<br /><small>Google reviews</small></span></div></div></section>
    <section class="spice section-pad"><div class="spice__sun" aria-hidden="true">✦</div><div><p class="eyebrow">{t.spiceEyebrow}</p><h2 set:html={t.spiceTitle} /><p>{t.spiceText}</p></div><ol><li><b>01</b><span>○○○</span><em>{index === 2 ? 'हल्का' : index === 1 ? 'Mild' : 'Łagodnie'}</em></li><li><b>02</b><span>●●○</span><em>{index === 2 ? 'मध्यम' : index === 1 ? 'Medium' : 'Średnio'}</em></li><li><b>03</b><span>●●●</span><em>{index === 2 ? 'तीखा' : index === 1 ? 'Fire' : 'Ostro'}</em></li></ol></section>
    <section class="visit-block"><div><p class="eyebrow eyebrow--dark">{t.visitEyebrow}</p><h2 set:html={t.visitTitle} /><p>{t.visitLead}</p><div class="visit-block__details"><span><b>{t.addressLabel}</b>Równoległa 2<br />02-232 Warszawa</span><span><b>{t.hoursLabel}</b>{t.hours}</span></div><a class="button button--dark" href="https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9" target="_blank" rel="noopener noreferrer">{t.map}<span>↗</span></a></div><a class="map-card" href="https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9" target="_blank" rel="noopener noreferrer"><span>RÓWNOLEGŁA</span><b>2</b><i>Warszawa · Włochy</i></a></section>
  </main>
  <Footer {lang} />
</BaseLayout>
