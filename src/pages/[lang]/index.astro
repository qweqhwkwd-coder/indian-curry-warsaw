---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import {languages,copy,dishes,langIndex,type Lang} from '../../i18n/content'; export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang]; const i=langIndex(lang); const order='https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.name} — ${t.hero}`} description={t.lead}><Header {lang}/><main id="main"><section class="hero"><div class="hero-copy"><p class="kicker">INDIAN CURRY WŁOCHY · WARSZAWA</p><h1>{t.hero}</h1><p>{t.lead}</p><div class="actions"><a class="button" href={order} target="_blank" rel="noopener noreferrer">{t.order} <span>↗</span></a><a class="button button-ghost" href="tel:+48500091313">{t.call}</a></div><small>{t.now}</small></div></section><section class="intro"><p class="kicker">{t.selected}</p><h2 set:html={t.menuTitle}/><p>{t.menuLead}</p></section><section class="menu-preview" id="menu"><div class="menu-heading"><p class="kicker">{t.nav.menu}</p><h2>{t.selected}</h2><a href={`/${lang}/menu`}>{t.menuLink} ↗</a></div><div>{dishes.map((dish,n)=><article class="dish"><span>0{n+1}</span><h3>{dish.name}</h3><p>{dish.description[i]}</p></article>)}</div></section><section class="story" id="story"><div class="story-photo"></div><div class="story-copy"><p class="kicker">{t.nav.story}</p><h2 set:html={t.storyTitle}/><p>{t.storyText}</p><div class="spice-line"><span>●</span><span>● ●</span><span>● ● ●</span></div></div></section><section class="visit"><div><p class="kicker">{t.nav.visit}</p><h2 set:html={t.visitTitle}/><p>{t.visitLead}</p><dl><div><dt>{t.addressLabel}</dt><dd>Równoległa 2, 02-232 Warszawa</dd></div><div><dt>{t.hoursLabel}</dt><dd>{t.hours}</dd></div></dl><div class="actions"><a class="button button-dark" href="https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9" target="_blank" rel="noopener noreferrer">{t.directions} <span>↗</span></a></div></div></section></main><Footer {lang}/></BaseLayout>
