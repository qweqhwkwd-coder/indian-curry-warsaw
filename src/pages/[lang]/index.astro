---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content';
export function getStaticPaths() { return languages.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Lang;
const t = copy[lang]; const i = langIndex(lang);
const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.name} | ${t.hero[0]} ${t.hero[1]}`} description={t.lead}>
  <Header {lang}/>
  <main id="main">
    <section class="new-hero">
      <div class="hero-orb one"></div><div class="hero-orb two"></div>
      <div class="hero-meta"><span>WARSZAWA / OCHOTA</span><span>EST. 2024</span></div>
      <div class="hero-title"><p class="hero-kicker">{t.name} <b>●</b> INDIAN KITCHEN</p><h1>{t.hero[0]} <em>{t.hero[1]}</em></h1><p>{t.lead}</p><a class="hero-order" href={orderUrl} target="_blank" rel="noopener noreferrer"><span>{t.order}</span><b>↗</b></a></div>
      <figure class="hero-photo"><img src="/images/hero-curry.jpg" width="1600" height="1067" alt="Indian curry with rice and spices" fetchpriority="high"/><figcaption>Cooked slow.<br/>Served bright.</figcaption></figure>
      <div class="hero-footer"><span>OPEN DAILY · {t.hours}</span><span>SCROLL TO TASTE ↓</span></div>
    </section>
    <section class="tape"><span>HOT FROM THE TANDOOR</span><b>✦</b><span>VEGETARIAN-FRIENDLY</span><b>✦</b><span>FULL OF FLAVOUR</span><b>✦</b><span>HOT FROM THE TANDOOR</span></section>
    <section class="menu-editorial"><div class="menu-heading"><p>01 / START HERE</p><h2>Choose your<br/><em>comfort level.</em></h2><a href={`/${lang}/menu`}>{t.nav[0]} <b>↗</b></a></div><div class="dish-stack">{dishes.map((dish, n) => <article class={`dish dish-${n + 1}`}><span class="dish-no">0{n + 1}</span><div><p>{dish.tag[i]}</p><h3>{dish.name}</h3><small>{dish.text[i]}</small></div><strong>{dish.price}</strong></article>)}</div></section>
    <section class="heat-section" id="story"><div class="heat-number">03</div><div class="heat-copy"><p>THE HEAT IS YOURS</p><h2>{t.spiceTitle}</h2><span>{t.spiceLead}</span></div><div class="heat-scale"><div><b>01</b><span>mild</span></div><div><b>02</b><span>medium</span></div><div><b>03</b><span>fire</span></div></div></section>
    <section class="visit-new"><div class="visit-card"><p>COME HUNGRY</p><h2>{t.visitTitle}</h2><div><span><b>ADDRESS</b>{t.address}</span><span><b>HOURS</b>{t.hours}</span></div><a href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} →</a></div><a class="address-graphic" href="https://maps.app.goo.gl/VK15ZGabbGj6RU1M7" target="_blank" rel="noopener noreferrer"><span>Równoległa</span><b>2</b><small>{t.map} ↗</small></a></section>
  </main>
  <Footer {lang}/>
</BaseLayout>
