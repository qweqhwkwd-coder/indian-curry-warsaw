---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Arrow from '../../components/Arrow.astro';
import Mark from '../../components/Mark.astro';
import {
  languages,
  copy,
  favourites,
  ORDER_URL,
  MAPS_URL,
  PHONE,
  type Lang,
} from '../../i18n/content';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
---

<BaseLayout {lang} title={`${t.name} — ${t.hero}`} description={t.lead}>
  <Header {lang} />

  <main id="main">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-copy">
        <p class="kicker">Indian Curry Włochy · Warszawa</p>
        <h1>{t.hero}</h1>
        <p class="hero-lead">{t.lead}</p>
        <div class="actions">
          <a class="button" href={ORDER_URL} target="_blank" rel="noopener noreferrer">
            {t.order} <Arrow />
          </a>
          <a class="button button-ghost" href={`tel:${PHONE}`}>{t.call}</a>
        </div>
        <small>{t.now}</small>
      </div>
    </section>

    <!-- Favourites -->
    <section class="favourites" id="menu">
      <div class="favourites-head">
        <p class="kicker">{t.selected}</p>
        <h2>{t.menuLead}</h2>
        <a class="text-link" href={`/${lang}/menu`}>{t.menuLink} <Arrow /></a>
      </div>
      <ul class="dish-grid">
        {favourites.map((dish, n) => (
          <li class="dish">
            <span class="dish-no">{String(n + 1).padStart(2, '0')}</span>
            <div class="dish-name">
              <Mark veg={dish.veg} {lang} />
              <h3>{dish.name}</h3>
            </div>
            <p>{dish.desc[lang]}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- Kitchen story -->
    <section class="story" id="story">
      <div class="story-photo" role="img" aria-label="Curry from the tandoor kitchen"></div>
      <div class="story-copy">
        <p class="kicker">{t.nav.story}</p>
        <h2 set:html={t.storyTitle} />
        <p>{t.storyText}</p>
        <div class="heat">
          <div class="heat-dots" aria-hidden="true"><i></i><i></i><i></i></div>
          <p>{t.heatScale}</p>
        </div>
      </div>
    </section>

    <!-- Visit -->
    <section class="visit">
      <div class="visit-inner">
        <p class="kicker">{t.nav.visit}</p>
        <h2 set:html={t.visitTitle} />
        <p class="visit-lead">{t.visitLead}</p>
        <dl>
          <div>
            <dt>{t.addressLabel}</dt>
            <dd>Równoległa 2, 02-232 Warszawa</dd>
          </div>
          <div>
            <dt>{t.hoursLabel}</dt>
            <dd>{t.hours}</dd>
          </div>
        </dl>
        <div class="actions">
          <a class="button button-dark" href={MAPS_URL} target="_blank" rel="noopener noreferrer">
            {t.directions} <Arrow />
          </a>
          <a class="button button-line" href={`/${lang}/visit`}>{t.nav.visit}</a>
        </div>
      </div>
    </section>
  </main>

  <Footer {lang} />
</BaseLayout>
