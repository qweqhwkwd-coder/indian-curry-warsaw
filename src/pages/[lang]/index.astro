---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import Arrow from '../../components/Arrow.astro'; import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content';
export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang]; const i=langIndex(lang); const orderUrl='https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.name} | ${t.hero[0]} ${t.hero[1]}`} description={t.lead}><Header {lang}/><main id="main">
  <section class="ritual-hero"><div class="ritual-hero__copy"><p>{t.name} · Warszawa</p><h1>{t.hero[0]} <em>{t.hero[1]}</em></h1><span>{t.lead}</span><a href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} <Arrow /></a></div></section>
  <section class="ritual-intro"><p>INDIAN CURRY 2</p><h2>{t.menuTitle}</h2><span>{t.menuLead}</span></section>
  <section class="ritual-menu"><div class="ritual-menu__heading"><p>{t.nav[0]}</p><h2>Butter chicken,<br/><em>paneer i tandoor.</em></h2><a href={`/${lang}/menu`}>{t.nav[0]} <Arrow /></a></div><div class="ritual-dishes">{dishes.map(d=><article><p>{d.tag[i]}</p><h3>{d.name}</h3><span>{d.text[i]}</span><strong>{d.price}</strong></article>)}</div></section>
  <section class="ritual-story" id="story"><div class="ritual-story__image"></div><div><p>{t.nav[1]}</p><h2>{t.spiceTitle}</h2><span>{t.spiceLead}</span><ul>{t.home.levels.map((level,n)=><li><b>0{n+1}</b>{level}</li>)}</ul></div></section>
  <section class="ritual-visit"><div><p>{t.nav[2]}</p><h2>{t.visitTitle}</h2><span><b>{t.home.address}</b>{t.address}</span><span><b>{t.home.hoursLabel}</b>{t.hours}</span><a href="https://maps.app.goo.gl/VK15ZGabbGj6RU1M7" target="_blank" rel="noopener noreferrer">{t.map} <Arrow /></a></div><div class="ritual-visit__photo"></div></section>
</main><Footer {lang}/></BaseLayout>
