---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { languages, copy, dishes, langIndex, type Lang } from '../../i18n/content';
export function getStaticPaths() { return languages.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Lang; const t = copy[lang]; const index = langIndex(lang); const orderUrl = 'https://indian-curry-rownolegla.order.app.hd.digital/menus';
---
<BaseLayout {lang} title={`${t.name} | ${t.hero[0]} ${t.hero[1]}`} description={t.lead}><Header {lang}/><main id="main"><section class="hero"><div><p class="kicker">✦ Równoległa 2 · Warszawa</p><h1>{t.hero[0]}<em>{t.hero[1]}</em></h1><p class="lead">{t.lead}</p><div class="actions"><a class="button primary" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} ↗</a><a class="button ghost" href={`/${lang}/menu`}>{t.nav[0]} ↓</a></div><p class="open"><b></b>{t.hours} · daily</p></div><img src="/images/hero-curry.jpg" width="1600" height="1067" alt="Indian curry with rice and spices" fetchpriority="high" /></section><section class="band"><span>Tandoor</span><b>✦</b><span>House sauces</span><b>✦</b><span>Vegetarian options</span><b>✦</b><span>Big portions</span></section><section class="section menu-preview"><p class="kicker">{t.nav[0]}</p><h2>{t.menuTitle}</h2><p class="section-lead">{t.menuLead}</p><div class="cards">{dishes.map((dish) => <article><p class="tag">{dish.tag[index]}</p><h3>{dish.name}</h3><p>{dish.text[index]}</p><div><strong>{dish.price}</strong><a href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} ↗</a></div></article>)}</div><a class="text-link" href={`/${lang}/menu`}>{t.nav[0]} →</a></section><section class="section spice" id="story"><div><p class="kicker">Heat, your way</p><h2>{t.spiceTitle}</h2></div><div><p class="section-lead">{t.spiceLead}</p><ol><li>● Mild</li><li>●● Medium</li><li>●●● Hot</li></ol></div></section><section class="visit"><div><p class="kicker">{t.nav[2]}</p><h2>{t.visitTitle}</h2><div class="details"><p><b>Address</b><a href="https://maps.app.goo.gl/VK15ZGabbGj6RU1M7" target="_blank" rel="noopener noreferrer">{t.address}</a></p><p><b>Hours</b>{t.hours}</p></div><a class="button dark" href={orderUrl} target="_blank" rel="noopener noreferrer">{t.order} ↗</a></div><a class="map" href="https://maps.app.goo.gl/VK15ZGabbGj6RU1M7" target="_blank" rel="noopener noreferrer"><strong>Równoległa<br/>2</strong><small>{t.map} ↗</small></a></section></main><Footer {lang}/></BaseLayout>
