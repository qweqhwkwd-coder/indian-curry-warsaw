---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { languages, copy, type Lang } from '../../i18n/content'; export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang];
---
<BaseLayout {lang} title={`${t.nav[2]} | ${t.name}`} description={`${t.address}. ${t.hours}.`}><Header {lang}/><main id="main" class="visit" style="padding-top:9rem"><div><p class="kicker">{t.nav[2]}</p><h1>{t.visitTitle}</h1><div class="details"><p><b>Address</b>{t.address}</p><p><b>Hours</b>{t.hours}</p></div><a class="button dark" href="https://indian-curry-rownolegla.order.app.hd.digital/menus" target="_blank" rel="noopener noreferrer">{t.order} ↗</a></div><a class="map" href="https://maps.app.goo.gl/VK15ZGabbGj6RU1M7" target="_blank" rel="noopener noreferrer"><strong>Równoległa<br/>2</strong><small>{t.map} ↗</small></a></main><Footer {lang}/></BaseLayout>
