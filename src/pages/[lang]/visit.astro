---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import {languages,copy,type Lang} from '../../i18n/content'; export function getStaticPaths(){return languages.map(lang=>({params:{lang}}))}; const lang=Astro.params.lang as Lang; const t=copy[lang];
---
<BaseLayout {lang} title={`${t.nav.visit} — ${t.name}`} description={t.visitPageLead}><Header {lang}/><main id="main" class="page visit-page"><section class="page-head"><p class="kicker">{t.nav.visit}</p><h1 set:html={t.visitPageTitle}/><p>{t.visitPageLead}</p><dl><div><dt>{t.addressLabel}</dt><dd>Równoległa 2<br/>02-232 Warszawa</dd></div><div><dt>{t.hoursLabel}</dt><dd>{t.hours}</dd></div><div><dt>TELEFON</dt><dd><a href="tel:+48500091313">+48 500 091 313</a></dd></div></dl><div class="actions"><a class="button" href="https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9" target="_blank" rel="noopener noreferrer">{t.directions} <span>↗</span></a><a class="button button-ghost" href="https://indian-curry-rownolegla.order.app.hd.digital/menus" target="_blank" rel="noopener noreferrer">{t.order}</a></div></section><div class="visit-art"><span>RÓWNOLEGŁA</span><b>2</b><i>WARSZAWA</i></div></main><Footer {lang}/></BaseLayout>
