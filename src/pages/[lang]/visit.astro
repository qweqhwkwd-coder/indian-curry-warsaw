---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import { languages, copy, type Lang } from '../../i18n/content';
export function getStaticPaths() { return languages.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Lang; const t = copy[lang];
---
<BaseLayout {lang} title={`${t.nav.visit} — ${t.name}`} description={t.visitLead}><Header {lang} light /><main id="main" class="visit-page"><section><p class="eyebrow eyebrow--dark">{t.visitEyebrow}</p><h1 set:html={t.visitTitle} /><p class="visit-page__lead">{t.visitLead}</p><div class="contact-grid"><span><b>{t.addressLabel}</b>Równoległa 2<br />02-232 Warszawa</span><span><b>{t.hoursLabel}</b>{t.hours}</span><span><b>TELEFON</b><a href="tel:+48500091313">+48 500 091 313</a></span></div><div class="visit-page__actions"><a class="button button--dark" href="https://maps.app.goo.gl/4Qmb9Q32fz2zGqhP9" target="_blank" rel="noopener noreferrer">{t.map}<span>↗</span></a><a class="text-link" href="https://indian-curry-rownolegla.order.app.hd.digital/menus" target="_blank" rel="noopener noreferrer">{t.order} <span>↗</span></a></div></section><div class="visit-page__visual"><b>02<br />232</b><span>RÓWNOLEGŁA 2<br />WARSZAWA</span></div></main><Footer {lang} /></BaseLayout>
