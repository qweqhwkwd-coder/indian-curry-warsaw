---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Arrow from '../../components/Arrow.astro';
import {
  languages,
  copy,
  ORDER_URL,
  MAPS_URL,
  PHONE,
  PHONE_DISPLAY,
  type Lang,
} from '../../i18n/content';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
// OpenStreetMap embed — no API key and no cookie-consent wall (works in the EU),
// unlike the Google Maps iframe. "Get directions" still opens Google Maps.
const mapEmbed =
  'https://www.openstreetmap.org/export/embed.html?bbox=20.9331%2C52.1923%2C20.9411%2C52.1973&layer=mapnik&marker=52.19479%2C20.93713';
---

<BaseLayout {lang} title={`${t.nav.visit} — ${t.name}`} description={t.visitPageLead}>
  <Header {lang} light />

  <main id="main" class="page visit-page">
    <section class="page-head">
      <p class="kicker">{t.nav.visit}</p>
      <h1 set:html={t.visitPageTitle} />
      <p class="page-lead">{t.visitPageLead}</p>

      <dl class="visit-details">
        <div>
          <dt>{t.addressLabel}</dt>
          <dd>Równoległa 2<br />02-232 Warszawa</dd>
        </div>
        <div>
          <dt>{t.hoursLabel}</dt>
          <dd>{t.hours}</dd>
        </div>
        <div>
          <dt>{t.phoneLabel}</dt>
          <dd><a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></dd>
        </div>
      </dl>

      <div class="actions">
        <a class="button" href={MAPS_URL} target="_blank" rel="noopener noreferrer">
          {t.directions} <Arrow />
        </a>
        <a class="button button-line" href={ORDER_URL} target="_blank" rel="noopener noreferrer">
          {t.order}
        </a>
      </div>
    </section>

    <div class="map">
      <iframe
        title={t.mapLabel}
        src={mapEmbed}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </main>

  <Footer {lang} />
</BaseLayout>
